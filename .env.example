# PostgreSQL connection string — for public feedback that renders on the site.
# Copy this file to ".env.local" and set your database URL.
#
# Format:  postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local:   postgresql://postgres:yourpassword@localhost:5432/krishaan
# Hosted:  (Neon / Vercel Postgres) usually ends with ?sslmode=require

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
